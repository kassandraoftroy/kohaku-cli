{
    "compilerOptions": {
      "target": "ES2022",
      "module": "ESNext",
      "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "~/*": [
        "node_modules/@kohaku-eth/plugins/dist/*"
      ]
    },
      "noEmit": true,
      "strict": true,
    "skipLibCheck": true,
      "esModuleInterop": true
    },
    "include": ["src"]
  }